# =============================================================
# TECH TURF — Unified Backend — Environment Variables Template
# Copy to .env for local dev
# Set these as environment variables on Railway / Render / VPS for production
# =============================================================

# --- Server ---
PORT=5000
NODE_ENV=production

# --- Security ---
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# --- Database ---
# Relative path works for local SQLite; for production keep the file in a persistent volume
DATABASE_URL=./database/database.sqlite

# --- Email (Gmail App Password) ---
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-16-char-app-password

# --- AI Integration ---
# IMPORTANT: Set this to enable AI chat functionality
# Get your API key from: https://ai.google.dev/ or your AI provider
NEXUS_AI_API_KEY=your-nexus-ai-key

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=your-google-oauth-client-id

# --- CORS ---
# Comma-separated list of allowed frontend origins.
# Cloudflare Pages deployments on *.pages.dev are automatically allowed.
# Add your custom domains here once configured.
CORS_ORIGIN=https://your-app.pages.dev,https://your-custom-domain.com
